# Copy to .env and adjust. All vars are prefixed TRAINPIPE_.

# API
TRAINPIPE_API_KEY=change-me-please
TRAINPIPE_HOST=0.0.0.0
TRAINPIPE_PORT=8080

# Storage (relative paths are resolved from the working dir at startup)
TRAINPIPE_DATA_DIR=./data

# MLflow tracking server (started via docker compose)
TRAINPIPE_MLFLOW_TRACKING_URI=http://localhost:5000

# GPU restriction (JSON list). Leave commented to autodetect all visible GPUs.
# TRAINPIPE_VISIBLE_GPUS=[0,1,2,3]

# Scheduler tuning
TRAINPIPE_POLL_INTERVAL_SEC=1.0
TRAINPIPE_HEARTBEAT_INTERVAL_SEC=5.0
